# Cache-Control headers for static builds
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/manifest.webmanifest
  Cache-Control: public, max-age=86400
/data/*
  Cache-Control: public, max-age=600

# Security and fallback settings
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://calendly.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com https://unpkg.com; font-src 'self' data: https://api.fontshare.com https://fonts.gstatic.com https://unpkg.com; img-src 'self' data: https://aaaryangupta.com https://images.unsplash.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-src 'self' https:;
